# Public product identity
APP_NAME=Balance
PRODUCT_NAME=Balance
PROJECT_SLUG=balance

# Infrastructure namespace exception
DEPLOYMENT_NAMESPACE=swe40006-project

# Local runtime defaults
APP_ENV=local
NODE_ENV=development
APP_VERSION=0.1.0
GIT_COMMIT=local
BUILD_ID=local-build
AWS_REGION=ap-southeast-5
WEB_PORT=3000
API_PORT=3001
PUBLIC_HTTP_PORT=3000
# In Docker Compose, web proxies to the internal API service over the Compose network.
API_BASE_URL=http://api:3001
API_PROXY_TARGET=http://api:3001
DESKTOP_API_BASE_URL=http://localhost:3000/api
API_BASE_PATH=/api
API_HEALTH_PATH=/api/health
API_VERSION_PATH=/api/version
NEXT_PUBLIC_API_BASE_PATH=/api
NEXT_PUBLIC_API_HEALTH_PATH=/api/health
NEXT_PUBLIC_API_VERSION_PATH=/api/version

# Database and queue (placeholders only)
DATABASE_URL=postgresql://balance:balance@postgres:5432/balance?schema=public
POSTGRES_USER=balance
POSTGRES_PASSWORD=balance
POSTGRES_DB=balance
REDIS_URL=redis://redis:6379
QUEUE_PROOF_NAME=queue_proof
EXTRACTION_QUEUE_NAME=document_extract

# OCR (placeholders only)
OCR_PROVIDER=textract
TESSERACT_LANG=eng
EXTRACTION_PROVIDER_DEFAULT=textract

# Storage (placeholders only)
STORAGE_DRIVER=filesystem
STORAGE_FILESYSTEM_ROOT=/data/balance-storage
S3_BUCKET=
S3_REGION=

# Auth (placeholders only)
JWT_SECRET=replace-this-local-only
JWT_EXPIRES_IN=1h
PASSWORD_PEPPER=replace-this-local-only

# Seed (placeholders only; do not commit real passwords)
SEED_CONSUMER_PASSWORD=replace-this-local-only
SEED_REVIEWER_PASSWORD=replace-this-local-only
SEED_ADMIN_PASSWORD=replace-this-local-only

# Observability (local-only placeholder)
GRAFANA_ADMIN_PASSWORD=change-me-for-local-only
