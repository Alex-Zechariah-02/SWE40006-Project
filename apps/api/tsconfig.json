{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": "../../",
    "paths": {
      "@balance/types": ["packages/types/src/index.ts"],
      "@balance/utils": ["packages/utils/src/index.ts"],
      "@balance/config": ["packages/config/src/index.ts"],
      "@balance/db": ["packages/db/src/index.ts"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
