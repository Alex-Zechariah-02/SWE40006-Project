{
  "name": "@balance/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.build.json",
    "dev": "pnpm exec tsx src/main.ts",
    "lint": "pnpm exec eslint -c ../../eslint.config.mjs src test --ext .ts",
    "start": "node dist/main.js",
    "typecheck": "pnpm exec tsc --noEmit -p tsconfig.json",
    "test": "pnpm exec vitest run test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.872.0",
    "@balance/config": "workspace:*",
    "@balance/db": "workspace:*",
    "@balance/schemas": "workspace:*",
    "@balance/types": "workspace:*",
    "@nestjs/common": "11.1.19",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-express": "11.1.19",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "bcryptjs": "3.0.3",
    "bullmq": "5.76.0",
    "ioredis": "5.10.1",
    "jose": "6.1.0",
    "pg": "8.20.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.1.5"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.19",
    "@types/express": "4.17.23",
    "@types/multer": "1.4.12",
    "@types/supertest": "6.0.3",
    "supertest": "7.1.4"
  }
}
