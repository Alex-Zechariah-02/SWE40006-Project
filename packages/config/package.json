{
  "name": "@balance/config",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@balance/types": "workspace:*",
    "@balance/utils": "workspace:*"
  },
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.build.json",
    "lint": "pnpm exec eslint src --ext .ts",
    "typecheck": "pnpm exec tsc --noEmit -p tsconfig.json",
    "test": "pnpm exec vitest run src"
  }
}
