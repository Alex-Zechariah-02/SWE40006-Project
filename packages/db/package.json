{
  "name": "@balance/db",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@prisma/client": "7.8.0",
    "@prisma/adapter-pg": "7.8.0",
    "bcryptjs": "3.0.3",
    "pg": "8.20.0"
  },
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.build.json",
    "lint": "pnpm exec eslint -c ../../eslint.config.mjs src prisma --ext .ts --ignore-pattern \"src/generated/**\"",
    "typecheck": "pnpm exec tsc --noEmit -p tsconfig.json"
  }
}
